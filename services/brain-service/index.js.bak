const express = require("express");
const app = express();

app.use(express.json());

// 🔓 CORS FIX (required for frontend)
app.use((req, res, next) => {
res.header("Access-Control-Allow-Origin", "");
res.header("Access-Control-Allow-Headers", "");
res.header("Access-Control-Allow-Methods", "*");
next();
});

app.post("/brain", (req, res) => {
const { liquidity, rates, crude, fii } = req.body;

let call = [];
let reasons = [];
let impact = [];
let risk = [];
let actions = [];
let message = "";
let confidence = "MEDIUM";
let horizon = "1-3 Months";

// ===== LOGIC =====

if (rates === "RISING") {
reasons.push("Interest rates rising");
impact.push("Rates ↑ → NBFC ↓ → Risk ↑");
impact.push("Rates ↑ → PSU Banks ↑ → Opportunity");

call.push("Reduce NBFC exposure");
call.push("Increase PSU Bank allocation");

risk.push("Rate-sensitive sectors under pressure");
confidence = "HIGH";
horizon = "3-6 Months";

}

if (crude === "RISING") {
reasons.push("Crude adding inflation pressure");
risk.push("Inflation risk increasing");
}

if (liquidity === "STRONG") {
reasons.push("RBI liquidity supportive");
}

if (fii === "SELLING") {
reasons.push("FII selling trend");
}

// ===== CLIENT MESSAGE =====
message =
"We are reducing NBFC exposure due to rising interest rates and increasing PSU bank allocation for better positioning.";

res.json({
call,
horizon,
confidence,
reasons,
impact,
risk,
actions: call,
message,
timestamp: new Date().toLocaleString(),
});
});

// 🚨 CRITICAL FIX → EXPOSE TO PUBLIC
app.listen(5000, "0.0.0.0", () => {
console.log("Brain service running on port 5000");
});
